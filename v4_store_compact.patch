 // ReadFromDisk
 // -----------------------------------------------------------------------------
-void V4Store::ReadFromDisk() {
-  DCHECK(task_runner_->RunsTasksInCurrentSequence());
-
-  std::string contents;
-  if (!base::ReadFileToString(store_path_, &contents)) {
-    RecordStoreReadResult(FAILED_TO_READ_FILE);
-    return;
-  }
+void V4Store::ReadFromDisk() {
+  DCHECK(task_runner_->RunsTasksInCurrentSequence());

-  V4StoreFileFormat file_format;
-  if (!file_format.ParseFromString(contents)) {
-    RecordStoreReadResult(FAILED_TO_READ_FILE);
+  // ── NEW: support both plain and zstd-compressed store files ────────────
+  //
+  // If the file ends with ".zst" (e.g. UrlSoceng.store.compact.zst)
+  // MaybeDecompress() transparently decompresses it.  For all other files
+  // the function simply reads and returns the bytes unchanged, so the
+  // existing code path is completely unaffected.
+  std::optional<std::string> contents = MaybeDecompress(store_path_);
+  if (!contents.has_value()) {
+    RecordStoreReadResult(FAILED_TO_READ_FILE);
     return;
   }
+  // ── END NEW ─────────────────────────────────────────────────────────────

+  V4StoreFileFormat file_format;
+  if (!file_format.ParseFromString(*contents)) {
+    RecordStoreReadResult(FAILED_TO_READ_FILE);
+    return;
+  }

   // ... rest of ReadFromDisk() is completely unchanged ...
   // (magic number check, version check, hash_prefix_map population, etc.)
 }

