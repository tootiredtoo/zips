+#include "third_party/zstd/src/lib/zstd.h"

+// 4-byte little-endian magic that starts every zstd frame.
+static constexpr uint32_t kZstdMagic = 0xFD2FB528u;

 namespace safe_browsing {

@@ -120,6 +123,60 @@ namespace safe_browsing {
 // ... existing helper functions unchanged ...

+// -----------------------------------------------------------------------------
+// MaybeDecompress
+// -----------------------------------------------------------------------------
+// static
+std::optional<std::string> V4Store::MaybeDecompress(
+    const base::FilePath& path) {
+  // Read the raw file bytes.
+  std::string raw;
+  if (!base::ReadFileToString(path, &raw)) {
+    DVLOG(1) << "V4Store: failed to read " << path.value();
+    return std::nullopt;
+  }
+
+  // Check for zstd magic in the first 4 bytes.
+  if (raw.size() < 4) {
+    return raw;   // too small to be either format; let the caller handle it
+  }
+  uint32_t magic;
+  memcpy(&magic, raw.data(), sizeof(magic));
+  if (magic != kZstdMagic) {
+    return raw;   // not compressed — return as-is
+  }
+
+  // Determine the decompressed size from the zstd frame header.
+  unsigned long long content_size =
+      ZSTD_getFrameContentSize(raw.data(), raw.size());
+
+  if (content_size == ZSTD_CONTENTSIZE_UNKNOWN) {
+    // Frame was written without a content-size field.
+    // Fall back to streaming decompression with a 64 MiB upper bound.
+    // (Safe Browsing databases are well under this limit.)
+    constexpr size_t kMaxDecompressedSize = 64u * 1024 * 1024;
+    std::string out(kMaxDecompressedSize, '\0');
+    size_t n = ZSTD_decompress(out.data(), kMaxDecompressedSize,
+                               raw.data(), raw.size());
+    if (ZSTD_isError(n)) {
+      DVLOG(1) << "V4Store: zstd streaming decompress error: "
+               << ZSTD_getErrorName(n);
+      return std::nullopt;
+    }
+    out.resize(n);
+    return out;
+  }
+
+  if (content_size == ZSTD_CONTENTSIZE_ERROR) {
+    DVLOG(1) << "V4Store: zstd frame header corrupt in " << path.value();
+    return std::nullopt;
+  }
+
+  // Allocate exact buffer and decompress.
+  std::string out(static_cast<size_t>(content_size), '\0');
+  size_t n = ZSTD_decompress(out.data(), out.size(),
+                             raw.data(), raw.size());
+  if (ZSTD_isError(n)) {
+    DVLOG(1) << "V4Store: zstd decompress error: " << ZSTD_getErrorName(n);
+    return std::nullopt;
+  }
+  out.resize(n);
+  return out;
+}

